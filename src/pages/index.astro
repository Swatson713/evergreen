---
/**
 * index.astro — Evergreen Archaeology Homepage
 *
 * Sections:
 *  1. Hero         — dynamic from Keystatic (headline, subtext, background image)
 *  2. Services     — static CRM service cards
 *  3. Projects     — dynamic 3-column grid from Keystatic projects collection
 *  4. About        — static firm overview
 *  5. Contact      — static contact CTA
 */
import Layout from '../layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

// ── Read Keystatic data at build time ──────────────────────────────────────
const reader = createReader(process.cwd(), keystaticConfig);

// Singletons — gracefully return null if no content saved yet.
const homeData   = await reader.singletons.home.read();
const resumeData = await reader.singletons.resume.read();
const aboutData   = await reader.singletons.about.read();
const contactData = await reader.singletons.contact.read();

// Projects collection — sorted: featured first, then most-recent date.
const rawProjects = await reader.collections.projects.all();
const projects = rawProjects.sort((a, b) => {
  if (a.entry.featured && !b.entry.featured) return -1;
  if (!a.entry.featured && b.entry.featured) return 1;
  // Fallback: sort by date descending (ISO strings compare lexicographically)
  const da = a.entry.date ?? '';
  const db = b.entry.date ?? '';
  return db.localeCompare(da);
});

// ── Hero content (with safe fallbacks) ─────────────────────────────────────
const headline   = homeData?.headline  ?? 'Preserving the Past, Informing the Future';
const subtext    = homeData?.subtext   ?? 'Expert Cultural Resource Management and archaeological consulting services throughout the Pacific Northwest.';
const heroImage  = homeData?.heroImage ?? null;
const ctaPrimary = homeData?.ctaPrimary   ?? 'Explore Our Services';
const ctaSecond  = homeData?.ctaSecondary ?? 'View Field Projects';

// ── Resume PDF path ─────────────────────────────────────────────────────────
// Only render download buttons when a file has actually been uploaded.
// Showing the button before upload silently 404s on click.
const hasCv      = !!(resumeData?.cvFile);
const resumeHref = resumeData?.cvFile ?? '#';
const resumeLabel = resumeData?.buttonLabel ?? 'Download CV';

// ── About section content (with safe fallbacks) ─────────────────────────────
const aboutEyebrow     = aboutData?.eyebrow  ?? 'About the Firm';
const aboutHeading     = aboutData?.heading  ?? 'Field-Tested Expertise. Collaborative Practice.';
const aboutParagraphs  = (aboutData?.paragraphs ?? []).filter(Boolean) as string[];
const aboutPhoto       = aboutData?.photo    ?? null;
const aboutPhotoAlt    = aboutData?.photoAlt ?? null;
const aboutCredentials = (aboutData?.credentials ?? []).filter(
  (c): c is { abbr: string; label: string } => !!(c?.abbr && c?.label)
);

// Fall back to hardcoded credentials only if none are configured yet
const defaultCredentials = [
  { abbr: 'RPA',  label: 'Register of Professional Archaeologists' },
  { abbr: 'NHPA', label: 'Section 106 Specialist' },
  { abbr: 'NEPA', label: 'Environmental Review' },
  { abbr: 'PNW',  label: 'Pacific Northwest Focus' },
];
const credentials = aboutCredentials.length > 0 ? aboutCredentials : defaultCredentials;

// Fall back to hardcoded paragraphs if none are configured yet
const defaultParagraphs = [
  'Evergreen Archaeology is a Pacific Northwest–based cultural resource management firm providing rigorous, scientifically grounded archaeological services to federal agencies, tribal governments, municipalities, and private sector clients.',
  'Our approach combines thorough field methodology with deep regulatory knowledge — ensuring that each project meets the highest standards of professional practice while remaining responsive to client schedules and budgets.',
  'We are committed to meaningful consultation with Native American tribes and descendant communities, recognizing that responsible CRM work requires relationship-building alongside technical excellence.',
];
const paragraphs = aboutParagraphs.length > 0 ? aboutParagraphs : defaultParagraphs;

// ── Contact section content ─────────────────────────────────────────────────
const contactHeading    = contactData?.heading     ?? 'Ready to Start Your Project?';
const contactSubtext    = contactData?.subtext     ?? 'Whether you need a Phase I survey, Section 106 consultation, or a comprehensive CRM plan, reach out and we\'ll respond within one business day.';
const contactEmail      = contactData?.email       ?? 'info@evergreenarchaeology.com';
const contactPhone      = contactData?.phone       ?? null;
const contactAddress    = contactData?.address     ?? 'Pacific Northwest, USA';
const contactFormspree  = contactData?.formspreeId ?? null;
const contactFormHeading = contactData?.formHeading ?? 'Send a Message';

// ── Static services data ────────────────────────────────────────────────────
const services = [
  {
    title: 'Section 106 Compliance',
    description:
      'Expert guidance through the federal review process required under Section 106 of the National Historic Preservation Act. We coordinate with federal agencies, SHPOs, and consulting parties to meet all regulatory milestones on time.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>`,
  },
  {
    title: 'Archaeological Surveys',
    description:
      'Phase I pedestrian surveys, systematic shovel testing, and intensive subsurface investigations designed to identify, delineate, and evaluate cultural resources in direct accordance with state and federal guidelines.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>`,
  },
  {
    title: 'Cultural Resource Assessments',
    description:
      'Comprehensive literature reviews, background research, National Register evaluations, and ethnographic records analysis to assess the archaeological sensitivity and historic context of any project area.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
  },
  {
    title: 'Archaeological Monitoring',
    description:
      'On-site monitoring during ground-disturbing activities to identify and document unanticipated cultural resource discoveries and ensure regulatory compliance from first ground-break to project close-out.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>`,
  },
  {
    title: 'Phase III Data Recovery',
    description:
      'Rigorous large-scale excavations, artifact analysis, faunal and botanical studies, and detailed technical reporting to mitigate adverse effects on significant archaeological sites before development proceeds.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>`,
  },
  {
    title: 'NHPA & NEPA Consulting',
    description:
      'Technical writing and regulatory support for Environmental Impact Statements (EIS), Environmental Assessments (EA), and Historic Properties reports ensuring full compliance with federal and state law.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/>`,
  },
];
---

<Layout
  title="Home"
  description={subtext}
  image={heroImage ?? undefined}
>

  <!-- ════════════════════════════════════════════════════════════
       1. HERO
       ════════════════════════════════════════════════════════════ -->
  <section
    id="hero"
    class="relative flex items-center justify-center text-white overflow-hidden"
    style="min-height: 70vh;"
    aria-label="Hero"
  >
    <!-- Background gradient always fills the section -->
    <div
      class="absolute inset-0"
      style="background: radial-gradient(ellipse at center, #3a5c2e 0%, #294523 35%, #1a3318 70%, #0f1e0d 100%);"
      aria-hidden="true"
    ></div>

    <!-- Hero image: centered and contained so logos / seals display correctly -->
    {heroImage && (
      <div class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
        <img
          src={heroImage}
          alt="Evergreen Archaeology"
          class="h-full w-full max-h-[95%] max-w-[960px] object-contain opacity-70"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    )}

    <!-- Dark overlay for legibility -->
    <div class="absolute inset-0 hero-overlay" aria-hidden="true"></div>

    <!-- Grain texture overlay (subtle depth) -->
    <div
      class="absolute inset-0 opacity-20 mix-blend-overlay pointer-events-none"
      style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E&quot;);"
      aria-hidden="true"
    ></div>

    <!-- Hero copy -->
    <div class="relative z-10 text-center px-4 sm:px-6 max-w-4xl mx-auto py-16">
      <!-- Eyebrow badge -->
      <p class="inline-block text-green-300 text-xs font-semibold uppercase tracking-widest border border-green-400/40 bg-green-900/30 rounded-full px-4 py-1 mb-5">
        Cultural Resource Management
      </p>

      <h1 class="font-serif font-bold text-3xl sm:text-4xl md:text-5xl leading-tight mb-4 drop-shadow-lg">
        {headline}
      </h1>

      <p class="text-stone-200 text-base sm:text-lg max-w-xl mx-auto mb-8 leading-relaxed font-light">
        {subtext}
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="#services" class="btn-primary px-7 py-3">
          {ctaPrimary}
        </a>
        <a href="/projects" class="btn-outline px-7 py-3">
          {ctaSecond}
        </a>
      </div>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 opacity-60" aria-hidden="true">
      <span class="text-white text-xs tracking-widest uppercase">Scroll</span>
      <svg class="w-5 h-5 text-white animate-bounce" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════════
       2. SERVICES
       ════════════════════════════════════════════════════════════ -->
  <section id="services" class="py-24 bg-white scroll-offset" aria-labelledby="services-heading">
    <div class="section-container">

      <!-- Section header -->
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="section-eyebrow">What We Do</p>
        <h2 id="services-heading" class="section-heading mb-4">
          Full-Spectrum CRM Services
        </h2>
        <p class="text-stone-500 text-base leading-relaxed">
          From pre-project compliance through mitigation and reporting, Evergreen Archaeology delivers rigorous, client-focused archaeological services on schedule and within regulatory requirements.
        </p>
      </div>

      <!-- 3-column service grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <article class="group bg-stone-50 hover:bg-white border border-stone-200 hover:border-[#294523]/20 hover:shadow-md rounded-sm p-7 transition-all duration-300">
            <!-- Icon -->
            <div class="w-11 h-11 rounded-sm bg-[#294523]/10 group-hover:bg-[#294523] flex items-center justify-center mb-5 transition-colors duration-300">
              <svg
                class="w-5 h-5 text-[#294523] group-hover:text-white transition-colors duration-300"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
                set:html={service.icon}
              />
            </div>
            <h3 class="font-serif font-semibold text-stone-900 text-lg mb-3 leading-snug">
              {service.title}
            </h3>
            <p class="text-stone-500 text-sm leading-relaxed">
              {service.description}
            </p>
          </article>
        ))}
      </div>

      <!-- Compliance badges -->
      <div class="mt-14 pt-10 border-t border-stone-200 flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
        {['Section 106 / NHPA', 'NEPA Compliance', 'Washington SEPA', 'National Register Evaluations', 'Tribal Consultation'].map((badge) => (
          <span class="text-stone-400 text-xs font-medium uppercase tracking-wider">{badge}</span>
        ))}
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════════
       3. PROJECTS
       ════════════════════════════════════════════════════════════ -->
  <section id="projects" class="py-24 bg-stone-50" aria-labelledby="projects-heading">
    <div class="section-container">

      <!-- Section header -->
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12">
        <div>
          <p class="section-eyebrow">Field Work</p>
          <h2 id="projects-heading" class="section-heading">
            Recent Projects
          </h2>
        </div>
        <a
          href="/projects"
          class="shrink-0 inline-flex items-center gap-1.5 text-sm font-medium text-[#294523] hover:text-[#568a42] transition-colors"
          aria-label="View all field projects"
        >
          View all projects
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      {projects.length === 0 ? (
        <!-- Empty state: shown until first project is added via Keystatic -->
        <div class="text-center py-20 border-2 border-dashed border-stone-200 rounded-sm bg-white">
          <svg class="w-10 h-10 text-stone-300 mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
          </svg>
          <p class="text-stone-400 text-sm font-medium">No projects yet.</p>
          <p class="text-stone-400 text-xs mt-1">
            Add your first project via the
            <a href="/keystatic" class="text-[#294523] underline hover:no-underline">Keystatic admin</a>.
          </p>
        </div>
      ) : (
        <!-- 3-column responsive project grid (max 6 on homepage) -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {projects.slice(0, 6).map(({ slug, entry }) => (
            <article class="card-hover group">
              <a
                href={`/projects/${slug}`}
                class="block bg-white rounded-sm overflow-hidden shadow-sm border border-stone-200 h-full"
                aria-label={`View project: ${entry.title}`}
              >
                <!-- Thumbnail -->
                <div class="img-zoom aspect-4/3 bg-stone-100">
                  {entry.coverImage ? (
                    <img
                      src={entry.coverImage}
                      alt={`Cover photo for ${entry.title}`}
                      class="w-full h-full object-cover"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center bg-stone-100">
                      <svg class="w-8 h-8 text-stone-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
                      </svg>
                    </div>
                  )}
                </div>

                <!-- Card body -->
                <div class="p-5">
                  <!-- Location + type tags -->
                  <div class="flex flex-wrap items-center gap-2 mb-2">
                    {entry.location && (
                      <span class="text-[#568a42] text-xs font-medium uppercase tracking-wide">
                        {entry.location}
                      </span>
                    )}
                    {entry.projectType && entry.projectType !== 'other' && (
                      <span class="text-stone-400 text-xs">·</span>
                      <span class="text-stone-400 text-xs capitalize">
                        {entry.projectType.replace(/-/g, ' ')}
                      </span>
                    )}
                  </div>

                  <h3 class="font-serif font-semibold text-stone-900 text-lg leading-snug mb-2 group-hover:text-[#294523] transition-colors">
                    {entry.title}
                  </h3>

                  {entry.summary && (
                    <p class="text-stone-500 text-sm leading-relaxed line-clamp-2 mb-3">
                      {entry.summary}
                    </p>
                  )}

                  <div class="flex items-center justify-between pt-3 border-t border-stone-100">
                    {entry.date && (
                      <time
                        datetime={entry.date}
                        class="text-stone-400 text-xs"
                      >
                        {new Date(entry.date + 'T00:00:00').toLocaleDateString('en-US', {
                          year: 'numeric', month: 'long',
                        })}
                      </time>
                    )}
                    <span class="text-[#294523] text-xs font-medium group-hover:underline ml-auto">
                      View project →
                    </span>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      )}

      {projects.length > 6 && (
        <div class="text-center mt-12">
          <a href="/projects" class="btn-outline-dark inline-flex">
            See All {projects.length} Projects
          </a>
        </div>
      )}
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════════
       4. ABOUT
       ════════════════════════════════════════════════════════════ -->
  <section id="about" class="py-24 bg-white scroll-offset" aria-labelledby="about-heading">
    <div class="section-container">
      <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <!-- Text -->
        <div>
          <p class="section-eyebrow">{aboutEyebrow}</p>
          <h2 id="about-heading" class="section-heading mb-6">
            {aboutHeading}
          </h2>
          <div class="space-y-4 text-stone-600 leading-relaxed">
            {paragraphs.map((para) => (
              <p>{para}</p>
            ))}
          </div>

          <div class="mt-8 flex flex-wrap gap-4">
            {hasCv && (
              <a href={resumeHref} target="_blank" rel="noopener noreferrer" class="btn-primary">
                <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
                {resumeLabel}
              </a>
            )}
            <a href="#contact" class="btn-outline-dark">Get in Touch</a>
          </div>
        </div>

        <!-- Right column: photo (if uploaded) + credentials grid -->
        <div class="flex flex-col gap-6">
          {aboutPhoto && (
            <div class="rounded-sm overflow-hidden shadow-md border border-stone-200">
              <img
                src={aboutPhoto}
                alt={aboutPhotoAlt ?? 'About Evergreen Archaeology'}
                class="w-full h-auto object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
          )}
          <div class="grid grid-cols-2 gap-4">
            {credentials.map((cred) => (
              <div class="bg-stone-50 border border-stone-200 rounded-sm p-6 text-center">
                <p class="font-serif text-2xl font-bold text-[#294523] mb-1">{cred.abbr}</p>
                <p class="text-stone-500 text-xs leading-snug">{cred.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════════
       5. CONTACT
       ════════════════════════════════════════════════════════════ -->
  <section
    id="contact"
    class="py-24 bg-[#294523] text-white scroll-offset"
    aria-labelledby="contact-heading"
  >
    <div class="section-container">

      <!-- Top: heading + contact info -->
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <p class="text-green-300 text-xs font-semibold uppercase tracking-widest mb-3">Get in Touch</p>
          <h2 id="contact-heading" class="font-serif font-bold text-3xl md:text-4xl lg:text-5xl text-white mb-5 leading-tight">
            {contactHeading}
          </h2>
          <p class="text-green-100/80 text-lg leading-relaxed max-w-xl mx-auto">
            {contactSubtext}
          </p>
        </div>

        <!-- Contact details row -->
        <div class="flex flex-wrap justify-center gap-6 mb-12">
          <a
            href={`mailto:${contactEmail}`}
            class="inline-flex items-center gap-2 bg-white text-[#294523] hover:bg-green-50 font-semibold text-sm px-8 py-3.5 rounded-sm transition-colors"
          >
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            {contactEmail}
          </a>

          {contactPhone && (
            <a
              href={`tel:${contactPhone.replace(/\D/g, '')}`}
              class="inline-flex items-center gap-2 border border-white/40 hover:bg-white/10 text-white font-medium text-sm px-8 py-3.5 rounded-sm transition-colors"
            >
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              {contactPhone}
            </a>
          )}

          {hasCv && (
            <a
              href={resumeHref}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 border border-white/40 hover:bg-white/10 text-white font-medium text-sm px-8 py-3.5 rounded-sm transition-colors"
            >
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              {resumeLabel}
            </a>
          )}
        </div>

        <!-- Contact form (only shown when a Formspree ID is configured) -->
        {contactFormspree && (
          <div class="bg-white/10 border border-white/20 rounded-sm p-8 max-w-2xl mx-auto">
            <h3 class="font-serif font-semibold text-white text-xl mb-6">{contactFormHeading}</h3>
            <form
              action={`https://formspree.io/f/${contactFormspree}`}
              method="POST"
              class="space-y-5"
            >
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="contact-name" class="block text-green-200 text-xs font-semibold uppercase tracking-widest mb-1.5">
                    Name <span aria-hidden="true">*</span>
                  </label>
                  <input
                    id="contact-name"
                    type="text"
                    name="name"
                    required
                    autocomplete="name"
                    placeholder="Jane Smith"
                    class="w-full bg-white/10 border border-white/30 text-white placeholder:text-white/40 rounded-sm px-4 py-2.5 text-sm focus:outline-none focus:border-white/70 focus:bg-white/15 transition-colors"
                  />
                </div>
                <div>
                  <label for="contact-email" class="block text-green-200 text-xs font-semibold uppercase tracking-widest mb-1.5">
                    Email <span aria-hidden="true">*</span>
                  </label>
                  <input
                    id="contact-email"
                    type="email"
                    name="email"
                    required
                    autocomplete="email"
                    placeholder="jane@example.com"
                    class="w-full bg-white/10 border border-white/30 text-white placeholder:text-white/40 rounded-sm px-4 py-2.5 text-sm focus:outline-none focus:border-white/70 focus:bg-white/15 transition-colors"
                  />
                </div>
              </div>

              <div>
                <label for="contact-org" class="block text-green-200 text-xs font-semibold uppercase tracking-widest mb-1.5">
                  Organization / Agency
                </label>
                <input
                  id="contact-org"
                  type="text"
                  name="organization"
                  autocomplete="organization"
                  placeholder="Optional"
                  class="w-full bg-white/10 border border-white/30 text-white placeholder:text-white/40 rounded-sm px-4 py-2.5 text-sm focus:outline-none focus:border-white/70 focus:bg-white/15 transition-colors"
                />
              </div>

              <div>
                <label for="contact-service" class="block text-green-200 text-xs font-semibold uppercase tracking-widest mb-1.5">
                  Service Needed
                </label>
                <select
                  id="contact-service"
                  name="service"
                  class="w-full bg-[#294523] border border-white/30 text-white rounded-sm px-4 py-2.5 text-sm focus:outline-none focus:border-white/70 transition-colors appearance-none"
                >
                  <option value="">Select a service…</option>
                  <option value="Section 106 Compliance">Section 106 Compliance</option>
                  <option value="Archaeological Survey">Archaeological Survey</option>
                  <option value="Cultural Resource Assessment">Cultural Resource Assessment</option>
                  <option value="Archaeological Monitoring">Archaeological Monitoring</option>
                  <option value="Phase III Data Recovery">Phase III Data Recovery</option>
                  <option value="NHPA / NEPA Consulting">NHPA / NEPA Consulting</option>
                  <option value="Other">Other</option>
                </select>
              </div>

              <div>
                <label for="contact-message" class="block text-green-200 text-xs font-semibold uppercase tracking-widest mb-1.5">
                  Message <span aria-hidden="true">*</span>
                </label>
                <textarea
                  id="contact-message"
                  name="message"
                  required
                  rows="5"
                  placeholder="Briefly describe your project, location, and timeline…"
                  class="w-full bg-white/10 border border-white/30 text-white placeholder:text-white/40 rounded-sm px-4 py-2.5 text-sm focus:outline-none focus:border-white/70 focus:bg-white/15 transition-colors resize-y"
                ></textarea>
              </div>

              <!-- Honeypot anti-spam field — hidden from real users -->
              <input type="text" name="_gotcha" class="hidden" aria-hidden="true" tabindex="-1" />

              <button
                type="submit"
                class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-white text-[#294523] hover:bg-green-50 font-semibold text-sm px-8 py-3.5 rounded-sm transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                </svg>
                Send Message
              </button>
            </form>
          </div>
        )}

        <!-- Location note -->
        {contactAddress && (
          <p class="text-center text-green-200/60 text-xs mt-10 tracking-wide">{contactAddress}</p>
        )}
      </div>

    </div>
  </section>

</Layout>
